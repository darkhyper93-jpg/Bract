# Servidor
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

# Supabase (proyecto dev separado del prod — README §12.2)
# Para producción en Render usar el connection string en modo Transaction (puerto 6543):
# postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# Se obtiene en: Supabase Dashboard → Settings → Database → Connection string → Transaction
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
SUPABASE_URL=https://[project].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Upstash Redis — REST API (para @upstash/redis: blacklist JWT, rate limit, cache)
UPSTASH_REDIS_REST_URL=https://[region].upstash.io
UPSTASH_REDIS_REST_TOKEN=

# NOTA: BULLMQ_REDIS_URL eliminado — workers son síncronos para MVP. Ver error.md.
# @upstash/redis (REST) sigue siendo requerido para blacklist JWT, rate limit y cache.
# Para reactivar BullMQ cuando el volumen lo justifique, ver los archivos *.worker.ts conservados.

# JWT RS256 — generar con:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#
# En Render: pegar el contenido con \n literales (no con saltos de línea reales).
# Convertir a \n literales con:
#   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=bract-files
CLOUDFLARE_R2_PUBLIC_URL=https://files.bract.app

# Resend (email transaccional)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@bract.app

# Logging
LOG_LEVEL=debug
